{
  "name": "uniswap-analyzer",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=packages/backend\" \"npm run dev --workspace=packages/frontend\"",
    "build": "npm run build --workspace=packages/backend && npm run build --workspace=packages/frontend",
    "backend": "npm run dev --workspace=packages/backend",
    "frontend": "npm run dev --workspace=packages/frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
